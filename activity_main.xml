<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Flight Information Card -->
        <net.skyscanner.backpack.card.BpkCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cornerStyle="large">

            <net.skyscanner.backpack.text.BpkText
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Flight SK123"
                android:padding="16dp"
                style="@style/bpkTextHeading2"/>

        </net.skyscanner.backpack.card.BpkCardView>


        <!-- Departure Card -->
        <net.skyscanner.backpack.card.BpkCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cornerStyle="large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <net.skyscanner.backpack.text.BpkText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Departure"
                    style="@style/bpkTextHeading3"/>

                <net.skyscanner.backpack.text.BpkText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BLR - 10:30 AM"
                    style="@style/bpkTextBodyDefault"/>

            </LinearLayout>

        </net.skyscanner.backpack.card.BpkCardView>


        <!-- Arrival Card -->
        <net.skyscanner.backpack.card.BpkCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cornerStyle="large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <net.skyscanner.backpack.text.BpkText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Arrival"
                    style="@style/bpkTextHeading3"/>

                <net.skyscanner.backpack.text.BpkText
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DXB - 12:45 PM"
                    style="@style/bpkTextBodyDefault"/>

            </LinearLayout>

        </net.skyscanner.backpack.card.BpkCardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>